msgid "Imagina CRM"
msgstr "Imagina CRM"

msgid "Plataforma de gestión de listas, registros y automatizaciones tipo ClickUp/Airtable nativa en WordPress."
msgstr "Lists, records, and automations platform — ClickUp/Airtable-style — native to WordPress."

#. Errores comunes
msgid "El nombre es obligatorio."
msgstr "Name is required."

msgid "El nombre no puede estar vacío."
msgstr "Name cannot be empty."

msgid "El slug no puede estar vacío."
msgstr "Slug cannot be empty."

msgid "Formato inválido. Usa snake_case: minúsculas, números y guiones bajos. Debe empezar por letra."
msgstr "Invalid format. Use snake_case: lowercase letters, numbers, and underscores. Must start with a letter."

msgid "Ya existe otra entidad con ese slug."
msgstr "Another entity already uses this slug."

msgid "Ese slug está reservado por el sistema. Elige otro."
msgstr "That slug is reserved by the system. Choose another."

msgid "La lista no existe."
msgstr "The list does not exist."

msgid "El campo no existe."
msgstr "The field does not exist."

msgid "El record no existe."
msgstr "The record does not exist."

msgid "Tipo de campo desconocido."
msgstr "Unknown field type."

msgid "Este tipo de campo no soporta unicidad."
msgstr "This field type does not support uniqueness."

msgid "Este campo es obligatorio."
msgstr "This field is required."

msgid "Valor inválido."
msgstr "Invalid value."

msgid "Email inválido."
msgstr "Invalid email."

msgid "URL inválida."
msgstr "Invalid URL."

msgid "Fecha inválida. Usa formato YYYY-MM-DD."
msgstr "Invalid date. Use YYYY-MM-DD format."

